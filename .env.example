# --- Local dev (`npm run dev`) ---
# Leave VITE_API_BASE_URL empty (browser uses /api — no CORS). Proxy target:
VITE_API_PROXY_TARGET=https://react-base-creator-backend-beta1.vercel.app
VITE_API_BASE_URL=
# Local Express instead: VITE_API_PROXY_TARGET=http://localhost:3001

# --- Production builds ---
# Full-stack Vercel: leave empty (same-origin /api).
# Split deploy (API on Render, etc.): set in Vercel project env vars at build time.
# VITE_API_BASE_URL=https://YOUR-SERVICE.onrender.com
VITE_API_BASE_URL=

# --- Optional: iframe preview URL (must be HTTPS in production) ---
# VITE_PREVIEW_URL=https://your-preview-host.example.com
