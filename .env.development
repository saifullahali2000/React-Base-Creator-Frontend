# Local dev: leave VITE_API_BASE_URL empty — browser uses /api (same origin, no CORS).
# Vite proxies /api to the target below (restart npm run dev after changes).
VITE_API_PROXY_TARGET=https://react-base-creator-backend-api.onrender.com
VITE_API_BASE_URL=

# Local backend instead: VITE_API_PROXY_TARGET=http://localhost:3001
